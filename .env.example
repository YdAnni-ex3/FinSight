# Copy to .env and fill in. NEVER commit the real .env.
# All app settings use the FINSIGHT_ prefix.

FINSIGHT_ENVIRONMENT=local
FINSIGHT_LOG_LEVEL=INFO

# ---- Postgres (matches docker-compose) ----
FINSIGHT_DATABASE_URL=postgresql://finsight:finsight@localhost:5432/finsight

# ---- Azure Blob Storage ----
# Local: Azurite well-known dev connection string (safe to commit, it's a public emulator key).
FINSIGHT_BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMA==;BlobEndpoint=http://127.0.0.1:10000/devstoreaccount1;
FINSIGHT_BLOB_CONTAINER=raw-statements

# ---- Azure OpenAI (Microsoft Foundry) — fill from Part 4 provisioning ----
FINSIGHT_AZURE_OPENAI_ENDPOINT=
FINSIGHT_AZURE_OPENAI_API_KEY=
FINSIGHT_AZURE_OPENAI_API_VERSION=2024-06-01
FINSIGHT_AZURE_OPENAI_CHAT_DEPLOYMENT=
FINSIGHT_AZURE_OPENAI_EMBEDDINGS_DEPLOYMENT=

# ---- Azure Key Vault (prod secrets source; leave blank for local) ----
FINSIGHT_KEY_VAULT_URL=

# ---- Pinecone (Phase 3) ----
FINSIGHT_PINECONE_API_KEY=
FINSIGHT_PINECONE_INDEX=finsight
FINSIGHT_PINECONE_CLOUD=aws
FINSIGHT_PINECONE_REGION=us-east-1

# ---- Kafka / Redpanda (matches docker-compose) ----
FINSIGHT_KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ---- Snowflake (analytics warehouse; leave blank until you create the trial) ----
FINSIGHT_SNOWFLAKE_ACCOUNT=
FINSIGHT_SNOWFLAKE_USER=
FINSIGHT_SNOWFLAKE_PASSWORD=
FINSIGHT_SNOWFLAKE_WAREHOUSE=COMPUTE_WH
FINSIGHT_SNOWFLAKE_DATABASE=FINSIGHT
FINSIGHT_SNOWFLAKE_SCHEMA=ANALYTICS
FINSIGHT_SNOWFLAKE_ROLE=

# ---- AWS Bedrock (multi-cloud LLM; leave chat model blank until AWS is set up) ----
FINSIGHT_LLM_PROVIDER=auto
FINSIGHT_AWS_REGION=us-east-1
FINSIGHT_BEDROCK_CHAT_MODEL=
FINSIGHT_BEDROCK_EMBED_MODEL=amazon.titan-embed-text-v2:0
# AWS creds use the standard chain: AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY
